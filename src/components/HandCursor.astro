<!-- Hand cursor: ambient emoji overlay, dual-cursor model (native cursor unaffected) -->
<div id="hand-cursor" aria-hidden="true">👋</div>

<script>
  const LERP = 0.12;
  const OFFSET_X = 24;
  const OFFSET_Y = 16;

  const STATES: Record<string, string> = {
    idle: '👋',
    pointing: '👆',
    grabbing: '✊',
  };

  const el = document.getElementById('hand-cursor') as HTMLElement;
  let targetX = 0, targetY = 0;
  let currentX = 0, currentY = 0;
  let currentState = 'idle';
  let rafStarted = false;

  function lerp(a: number, b: number, t: number): number {
    return a + (b - a) * t;
  }

  function tick() {
    currentX = lerp(currentX, targetX + OFFSET_X, LERP);
    currentY = lerp(currentY, targetY + OFFSET_Y, LERP);
    el.style.transform = `translate(${currentX}px, ${currentY}px)`;
    requestAnimationFrame(tick);
  }

  document.addEventListener('mousemove', (e: MouseEvent) => {
    targetX = e.clientX;
    targetY = e.clientY;
  });

  // Public API for external state control
  (window as any).HandCursor = {
    setState(state: string) {
      if (currentState === state) return;
      currentState = state;
      el.textContent = STATES[state] ?? STATES.idle;
    },
  };

  function attachListeners() {
    // Nav links and buttons → pointing
    document.querySelectorAll<HTMLElement>('a, button').forEach((node) => {
      node.addEventListener('mouseenter', () => (window as any).HandCursor.setState('pointing'));
      node.addEventListener('mouseleave', () => (window as any).HandCursor.setState('idle'));
    });

    // Project cards → grabbing (overrides pointing for cards that are links)
    document.querySelectorAll<HTMLElement>('.project-card').forEach((card) => {
      card.addEventListener('mouseenter', () => (window as any).HandCursor.setState('grabbing'));
      card.addEventListener('mouseleave', () => (window as any).HandCursor.setState('idle'));
    });
  }

  // Show cursor and attach listeners on each page load
  document.addEventListener('astro:page-load', () => {
    el.style.opacity = '1';
    attachListeners();
  });

  // Start RAF loop once
  if (!rafStarted) {
    rafStarted = true;
    tick();
  }
</script>
