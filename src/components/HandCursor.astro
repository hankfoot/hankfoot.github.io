<!-- Hand cursor: ambient scroll-driven emoji, no cursor tracking -->
<div id="hand-cursor" aria-hidden="true">✋</div>

<script>
  const LERP = 0.16;
  const MAX_PX_PER_FRAME = 22; // caps travel speed so hand glides, not whips

  const el = document.getElementById('hand-cursor') as HTMLElement;
  let targetX = 0, targetY = 0;
  let currentX = 0, currentY = 0;
  let waving = false;
  let rafStarted = false;

  function tick() {
    const dx = targetX - currentX;
    const dy = targetY - currentY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const step = Math.min(dist * LERP, MAX_PX_PER_FRAME);
    if (dist > 0.01) {
      currentX += (dx / dist) * step;
      currentY += (dy / dist) * step;
    }
    // Rotation in the same transform string = rotates around post-translate center
    const rotation = waving ? Math.sin(performance.now() / 550 * Math.PI) * 10 : 0;
    el.style.transform = `translate(${currentX}px, ${currentY}px) rotate(${rotation}deg)`;
    requestAnimationFrame(tick);
  }

  function waveAtTagline() {
    // Use Range for text-tight bounds on the block-level heading
    const heading = document.querySelector<HTMLElement>('.intro-greeting');
    if (!heading) return;
    const range = document.createRange();
    range.selectNodeContents(heading);
    const rect = range.getBoundingClientRect();
    const emojiH = el.getBoundingClientRect().height;
    targetX = rect.right + 12;
    targetY = rect.top + rect.height / 2 - emojiH * 0.5;
    el.textContent = '✋';
    waving = true;
  }

  function pointAtNavLink(section: string) {
    const link = document.querySelector<HTMLElement>(`a[data-section="${section}"]`);
    if (!link) return;
    // Measure actual text bounds, not the full-width element box
    const range = document.createRange();
    range.selectNodeContents(link);
    const rect = range.getBoundingClientRect();
    const emojiH = el.getBoundingClientRect().height;
    targetX = rect.right + 8;
    targetY = rect.top + rect.height / 2 - emojiH / 2;
    el.textContent = '👈';
    waving = false;
  }

  // Priority-ordered sections; first match wins
  const SECTIONS = [
    { key: 'intro',   selector: '.page-intro',  action: () => waveAtTagline() },
    { key: 'work',    selector: '.project-grid', action: () => pointAtNavLink('work') },
    { key: 'about',   selector: '#about',        action: () => pointAtNavLink('about') },
    { key: 'resume',  selector: '#resume',       action: () => pointAtNavLink('resume') },
    { key: 'contact', selector: '#contact',      action: () => pointAtNavLink('contact') },
  ];

  const visible = new Set<string>();

  function attachObservers() {
    visible.clear();
    for (const s of SECTIONS) {
      const node = document.querySelector(s.selector);
      if (!node) continue;
      // rootMargin clips the intersection root to the middle 40% of the viewport,
      // so a section is only "active" when it occupies the center of the screen
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) visible.add(s.key);
          else visible.delete(s.key);
          updateHand();
        },
        { rootMargin: '-30% 0px -30% 0px', threshold: 0 }
      );
      observer.observe(node);
    }
  }

  function isAtBottom(): boolean {
    return window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 32;
  }

  function updateHand() {
    if (isAtBottom()) { pointAtNavLink('contact'); return; }
    for (const s of SECTIONS) {
      if (visible.has(s.key)) { s.action(); return; }
    }
  }

  // Re-calc on scroll and resize so positions stay relative to layout
  window.addEventListener('scroll', () => updateHand(), { passive: true });
  window.addEventListener('resize', () => updateHand(), { passive: true });

  document.addEventListener('astro:page-load', () => {
    el.style.opacity = '1';
    attachObservers();
  });

  if (!rafStarted) {
    rafStarted = true;
    tick();
  }
</script>
