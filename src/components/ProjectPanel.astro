---
interface Props {
  title: string;
  year: number;
  tags: string[];
}

const { title, year, tags } = Astro.props;
---
<article class="project-panel" transition:animate="slide">
  <a href="/" class="project-panel-back">← back</a>

  <header class="project-panel-header">
    <h1 class="project-panel-title">{title}</h1>
    <p class="project-panel-meta">{year}</p>
    <ul class="tags">
      {tags.map(tag => <li class="tag">{tag}</li>)}
    </ul>
  </header>

  <div class="project-panel-body">
    <slot />
  </div>
</article>
