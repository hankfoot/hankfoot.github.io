---
type OutcomeItem = string | { text: string; url: string };

interface Props {
  title: string;
  hook?: string;
  summary?: string;
  year: number;
  tags: string[];
  org?: string;
  orgUrl?: string;
  contributions?: string[];
  tools?: string[];
  outcomes?: OutcomeItem[];
  thumb?: string;
}

import { parseInlineLinks } from '../utils/text';

const { title, hook, summary, year, tags, org, orgUrl, contributions, tools, outcomes } = Astro.props;
---

<article class="project-panel">
  <a href="/" class="project-panel-back">← back</a>

  <div class="pp-sections">

  <header class="ph-header">
    <h1 class="ph-title">{title}</h1>

    {hook && <p class="ph-hook">{hook}</p>}

    <div class="ph-meta">

      {org && (
        <div class="ph-meta-field">
          <span class="ph-meta-label">Context</span>
          <ul class="ph-meta-list">
            <li class="ph-meta-value" set:html={orgUrl ? `<a href="${orgUrl}" target="_blank" rel="noopener noreferrer">${org}</a>` : parseInlineLinks(org)} />
          </ul>
        </div>
      )}

      <div class="ph-meta-field">
        <span class="ph-meta-label">Year</span>
        <ul class="ph-meta-list">
          <li class="ph-meta-value">{year}</li>
        </ul>
      </div>

      {contributions && contributions.length > 0 && (
        <div class="ph-meta-field">
          <span class="ph-meta-label">Contributions</span>
          <ul class="ph-meta-list">
            {contributions.map(c => <li class="ph-meta-value">{c}</li>)}
          </ul>
        </div>
      )}

      {tools && tools.length > 0 && (
        <div class="ph-meta-field">
          <span class="ph-meta-label">Tools</span>
          <ul class="ph-meta-list">
            {tools.map(t => <li class="ph-meta-value">{t}</li>)}
          </ul>
        </div>
      )}

      {outcomes && outcomes.length > 0 && (
        <div class="ph-meta-field">
          <span class="ph-meta-label">Outcomes</span>
          <ul class="ph-meta-list">
            {outcomes.map(o => (
              <li
                class="ph-meta-value"
                set:html={typeof o === 'string'
                  ? parseInlineLinks(o)
                  : `<a href="${o.url}" target="_blank" rel="noopener noreferrer">${o.text}</a>`}
              />
            ))}
          </ul>
        </div>
      )}

    </div>

  </header>

  <div class="project-panel-body">
    <slot />
  </div>

  </div><!-- /.pp-sections -->
</article>
