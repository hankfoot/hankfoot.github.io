---
interface Props {
  people: Array<{ name: string; role: string; url?: string }>;
}

const { people } = Astro.props;
---

<div class="block-credits">
  <p class="block-credits-label">Credits</p>
  <ul class="block-credits-list">
    {people.map((person) => (
      <li class="block-credits-person">
        {person.url
          ? <a href={person.url} class="block-credits-name" target="_blank" rel="noopener noreferrer">{person.name}</a>
          : <span class="block-credits-name">{person.name}</span>
        }
        <span class="block-credits-sep"> - </span>
        <span class="block-credits-role">{person.role}</span>
      </li>
    ))}
  </ul>
</div>
