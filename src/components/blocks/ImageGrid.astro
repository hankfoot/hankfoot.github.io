---
import { Image } from 'astro:assets';

interface Props {
  images: string[];
  caption?: string;
}

const { images, caption } = Astro.props;
---
<figure class="block-image-grid">
  {images.map((src, i) => (
    <Image src={src} alt={`Image ${i + 1}`} width={1200} height={900} />
  ))}
  {caption && <figcaption style="grid-column: 1 / -1">{caption}</figcaption>}
</figure>
