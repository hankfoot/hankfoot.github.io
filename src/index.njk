---
layout: base.njk
title: Hank Duhaime — Portfolio
---

<div class="container page-content">

  <!-- 1. INTRO -->
  <section class="section-block" id="intro">
    <div class="section-header section-red">
      <div class="section-number">1</div>
      <h2 class="section-title">INTRO</h2>
    </div>
    <div class="intro-grid section-body-red">
      <div>
        <h1 class="intro-heading">
          My name's <span class="highlight">Hank</span>, nice to meet you!
        </h1>
        <p class="intro-text">
          I'm a design technologist specializing in immersive physical and digital media.
          <br><br>
          I'm currently prototyping the future of haptics, wearables, and robotics experiences at
          <a href="https://tech.facebook.com/reality-labs/" target="_blank" rel="noopener noreferrer">Meta Reality Labs Research.</a>
        </p>
        <div class="intro-ctas">
          <a href="#projects" class="btn-filled">View Work</a>
          <a href="#contact"  class="btn-outline">Contact</a>
        </div>
      </div>
      <div class="intro-photo">
        <img src="/media/home/intro/hero.png" alt="Hank Duhaime">
      </div>
    </div>
  </section>

  <!-- 2. FEATURED WORK -->
  <section class="section-block" id="projects" style="scroll-margin-top: 5rem;">
    <div class="section-header section-blue">
      <div class="section-number">2</div>
      <h2 class="section-title">FEATURED WORK</h2>
    </div>
    <div class="projects-grid section-body-blue">
      {% for project in collections.projects %}
      <div class="project-card">
        <div class="project-card-thumb">
          {% if project.data.thumbnail %}
            {% if project.data.thumbnail | isVideo %}
              <video src="{{ project.data.thumbnail }}" autoplay muted loop playsinline></video>
            {% else %}
              <img src="{{ project.data.thumbnail }}" alt="{{ project.data.title }}">
            {% endif %}
          {% else %}
            <div class="project-card-thumb-empty">No preview</div>
          {% endif %}
        </div>
        <div class="project-card-body">
          <div class="project-card-header">
            <h3 class="project-card-title">{{ project.data.title }}</h3>
            <span class="project-card-year">{{ project.data.period or project.data.year }}</span>
          </div>
          {% if project.data.org %}
            <p class="project-card-subtitle">{{ project.data.org }}</p>
          {% endif %}
          <p class="project-card-desc">{{ project.data.description }}</p>
          {% if project.data.tags %}
          <div class="tags">
            {% for tag in project.data.tags %}
              <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
          {% if project.data.featured != false %}
            <a href="{{ project.url }}" class="project-card-btn">View Work</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- 3. ABOUT -->
  <section class="section-block" id="about" style="scroll-margin-top: 5rem;">
    <div class="section-header section-green">
      <div class="section-number">3</div>
      <h2 class="section-title">ABOUT</h2>
    </div>
    <div class="two-col section-body-green">

      <!-- Left: Bio + Publications -->
      <div class="col-left col-pad">
        <h3 class="h3-label">Bio</h3>
        <div class="about-photo">
          <img src="/media/home/about/hank-duck.jpg" alt="Hank Duhaime">
        </div>
        <div class="about-paragraphs">
          {% for para in site.aboutParagraphs %}
            <p>{{ para }}</p>
          {% endfor %}
        </div>

        <h3 class="h3-label h3-label-mt">Publications</h3>
        <div class="pub-stack">
          {% for pub in site.publications %}
            {% if pub.link %}
              <a href="{{ pub.link }}" target="_blank" rel="noopener noreferrer" class="pub-item">
                <p class="pub-text">{{ pub.title }}</p>
              </a>
            {% else %}
              <div class="pub-item">
                <p class="pub-text">{{ pub.title }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <!-- Right: Experience, Education, Skills -->
      <div class="col-pad">
        <h3 class="h3-label">Experience</h3>
        <p style="font-size:0.75rem;color:#4b5563;margin-bottom:1.5rem;">
          Check out my <a href="#contact" style="text-decoration:underline;font-weight:700;">resume</a>
          or <a href="https://www.linkedin.com/in/henryduhaime/" target="_blank" rel="noopener noreferrer" style="text-decoration:underline;font-weight:700;">LinkedIn</a> for more detail!
        </p>
        <div class="exp-stack">
          {% for role in site.experience %}
          <div class="exp-card">
            <div class="exp-card-header">
              <span class="exp-company">{{ role.company }}</span>
              <span class="exp-dates">{{ role.dates }}</span>
            </div>
            <p class="exp-title">{{ role.title }}</p>
            <p class="exp-desc">{{ role.description }}</p>
          </div>
          {% endfor %}
        </div>

        <h3 class="h3-label">Education</h3>
        <div class="exp-stack">
          {% for ed in site.education %}
          <div class="exp-card">
            <p class="exp-company">{{ ed.institution }}</p>
            <p class="exp-title">{{ ed.degree }}</p>
          </div>
          {% endfor %}
        </div>

        <h3 class="h3-label">Skills</h3>
        <div class="skills-stack">
          {% for group in site.skillGroups %}
          <div>
            <p class="skills-group-label">{{ group.group }}</p>
            <div class="tags">
              {% for skill in group.skills %}
                <span class="tag">{{ skill }}</span>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </section>

  <!-- 4. CONTACT -->
  <section class="section-block" id="contact" style="scroll-margin-top: 5rem;">
    <div class="section-header section-orange">
      <div class="section-number">4</div>
      <h2 class="section-title">CONTACT</h2>
    </div>
    <div class="two-col">

      <div class="col-left col-pad section-body-orange">
        <p class="contact-heading">Come find me on the internet!</p>
        <p class="contact-text">{{ site.bio.contactMessage }}</p>
        <p class="contact-label">LOCATION</p>
        <p class="contact-value">{{ site.bio.location }}</p>
      </div>

      <div class="col-pad section-body-orange">
        <div class="social-buttons">
          {% if site.social.bluesky %}
          <a href="{{ site.social.bluesky }}" target="_blank" rel="noopener noreferrer" class="social-btn">
            <svg viewBox="0 0 568 501" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873C309.719 181.68 379.759 82.553 444.879 33.664C489.726 -1.611 568 -28.906 568 57.947C568 108.845 546.055 174.417 535.846 199.316C509.349 268.63 449.413 282.335 395.476 272.091C504.052 291.328 530.076 361.418 493.188 420.508C424.159 531.281 350.932 408.117 318.631 348.612C313.285 338.843 310.911 333.968 284 333.968C257.089 333.968 254.715 338.843 249.369 348.612C217.068 408.117 143.841 531.281 74.812 420.508C37.924 361.418 63.948 291.328 172.524 272.091C118.587 282.335 58.651 268.63 32.154 199.316C21.945 174.417 0 108.845 0 57.947C0 -28.906 78.274 -1.611 123.121 33.664Z"/>
            </svg>
            BLUESKY
          </a>
          {% endif %}
          {% if site.social.linkedin %}
          <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer" class="social-btn">
            <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LINKEDIN
          </a>
          {% endif %}
          {% if site.social.resume %}
          <a href="{{ site.social.resume }}" target="_blank" rel="noopener noreferrer" class="social-btn-filled">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            RESUME
          </a>
          {% endif %}
        </div>
      </div>

    </div>
  </section>

</div>
