---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => b.data.year - a.data.year);
---
<Base title="Hank Duhaime — Design Technologist">
  <section class="page-intro">
    <h1 class="intro-greeting">hi, I'm Hank</h1>
    <p class="intro-tagline">a <code class="intro-code">programmer</code> turned<br /><em>interaction designer</em></p>
    <p class="intro-sub">specializing in playful, hands-on experiences</p>
    <div class="intro-formerly">
      <span class="intro-formerly-label">formerly @</span>
      <span>meta reality labs research</span>
      <span>publicis sapient</span>
      <span>spellbound ar</span>
    </div>
  </section>
  <div class="project-grid" id="work">
    {sorted.map(project => (
      <ProjectCard
        href={`/work/${project.id.replace(/\.[^.]+$/, '')}`}
        title={project.data.title}
        year={project.data.year}
        tags={project.data.tags}
        thumb={project.data.thumb}
        summary={project.data.summary}
      />
    ))}
  </div>

  <section class="page-section" id="about">
    <p class="section-label">about</p>
    <div class="section-body">
      <p class="section-placeholder">Background and story coming soon.</p>
    </div>
  </section>

  <section class="page-section" id="cv">
    <p class="section-label">cv</p>
    <div class="section-body">
      <p class="section-placeholder">Experience and credentials coming soon.</p>
      <a
        href="https://hankduhaime.com/s/DuhaimeResume2023-V-Nov.pdf"
        target="_blank"
        rel="noopener"
        class="section-cta"
      >download pdf ↗</a>
    </div>
  </section>

  <section class="page-section" id="contact">
    <p class="section-label">contact</p>
    <div class="section-body">
      <p class="section-placeholder">Let's work together.</p>
      <div class="contact-list">
        <a href="mailto:hello.hank.d@gmail.com" class="contact-item">hello.hank.d@gmail.com</a>
        <a href="https://www.linkedin.com/in/henryduhaime/" target="_blank" rel="noopener" class="contact-item">linkedin</a>
        <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="contact-item">instagram</a>
      </div>
    </div>
  </section>
</Base>
